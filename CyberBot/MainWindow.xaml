<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot"
        Height="700"
        Width="900"
        MinHeight="650"
        MinWidth="850"
        Background="#1a1a2e">

    <Window.Resources>
        <!-- Base button style -->
        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background"     Value="#e94560"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Padding"        Value="12,6"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c73652"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green button variant -->
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#27ae60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1e8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Grey button variant -->
        <Style x:Key="GreyButton" TargetType="Button" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="CyberTextBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#0f3460"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="CaretBrush"   Value="White"/>
        </Style>

        <!-- Tab item style -->
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#0f3460"/>
            <Setter Property="Foreground"  Value="#aaa"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#0f3460"
                                Padding="18,8"
                                Margin="2,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#e94560"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#16213e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ── -->
        <TextBlock Grid.Row="0"
                   Text="⚡ CYBERBOT"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#e94560"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- ── Name input row ── -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12">
            <TextBlock Text="Your Name:"
                       Foreground="White"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBox x:Name="NameBox"
                     Width="200"
                     Style="{StaticResource CyberTextBox}"
                     FontSize="15"/>
            <Button Content="Start Chat"
                    Style="{StaticResource CyberButton}"
                    FontSize="15"
                    Margin="10,0,0,0"
                    Click="StartChat_Click"/>
        </StackPanel>

        <!-- ══════════════ TAB CONTROL ══════════════ -->
        <TabControl Grid.Row="2"
                    Background="#16213e"
                    BorderThickness="0"
                    Padding="0">

            <!-- ─────────────── CHAT TAB ─────────────── -->
            <TabItem Header="💬  Chat">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#0d1b2a"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,0,0,8">
                        <ScrollViewer x:Name="ChatScroller"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChatPanel"
                                        VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBox x:Name="UserInput"
                                 Width="680"
                                 Style="{StaticResource CyberTextBox}"
                                 FontSize="14"
                                 KeyDown="UserInput_KeyDown"/>
                        <Button Content="Send ➤"
                                Style="{StaticResource CyberButton}"
                                Margin="8,0,0,0"
                                Click="SendMessage_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─────────────── TASKS TAB ─────────────── -->
            <TabItem Header="📋  Tasks">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Task list -->
                    <Border Grid.Column="0"
                            Background="#0d1b2a"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Your Cybersecurity Tasks"
                                       Foreground="#e94560"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="4,4,4,8"/>
                            <ListBox x:Name="TaskListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     SelectionChanged="TaskListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0f3460"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#aaa"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding ReminderDisplay, StringFormat='⏰ {0}'}"
                                                               Foreground="#e94560"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding StatusDisplay}"
                                                           Foreground="#27ae60"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Add task form -->
                    <Border Grid.Column="1"
                            Background="#0d1b2a"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Add New Task"
                                       Foreground="#e94560"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Title *" Foreground="White" FontSize="12" Margin="0,0,0,3"/>
                            <TextBox x:Name="TaskTitleBox"
                                     Style="{StaticResource CyberTextBox}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Description" Foreground="White" FontSize="12" Margin="0,0,0,3"/>
                            <TextBox x:Name="TaskDescBox"
                                     Style="{StaticResource CyberTextBox}"
                                     Height="70"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Reminder (optional)" Foreground="White" FontSize="12" Margin="0,0,0,3"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBox x:Name="ReminderDaysBox"
                                         Style="{StaticResource CyberTextBox}"
                                         Width="60"
                                         Text="7"/>
                                <TextBlock Text=" days from now"
                                           Foreground="#aaa"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <CheckBox x:Name="SetReminderCheck"
                                      Content="Set a reminder"
                                      Foreground="White"
                                      FontSize="13"
                                      IsChecked="False"
                                      Margin="0,0,0,14"/>

                            <Button Content="➕  Add Task"
                                    Style="{StaticResource CyberButton}"
                                    Click="AddTask_Click"
                                    Margin="0,0,0,6"/>

                            <Separator Background="#333" Margin="0,10,0,10"/>

                            <TextBlock Text="Selected Task Actions"
                                       Foreground="#aaa"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="CompleteTaskBtn"
                                    Content="✔  Mark as Completed"
                                    Style="{StaticResource GreenButton}"
                                    IsEnabled="False"
                                    Margin="0,0,0,6"
                                    Click="CompleteTask_Click"/>
                            <Button x:Name="DeleteTaskBtn"
                                    Content="🗑  Delete Task"
                                    Style="{StaticResource GreyButton}"
                                    IsEnabled="False"
                                    Click="DeleteTask_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─────────────── QUIZ TAB ─────────────── -->
            <TabItem Header="🎮  Quiz">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Quiz header bar -->
                    <Border Grid.Row="0"
                            Background="#0d1b2a"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="QuizProgressText"
                                       Grid.Column="0"
                                       Text="Press 'Start Quiz' to begin!"
                                       Foreground="White"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="QuizScoreText"
                                       Grid.Column="1"
                                       Text="Score: 0 / 0"
                                       Foreground="#e94560"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                            <Button x:Name="StartQuizBtn"
                                    Grid.Column="2"
                                    Content="▶  Start Quiz"
                                    Style="{StaticResource CyberButton}"
                                    Click="StartQuiz_Click"/>
                        </Grid>
                    </Border>

                    <!-- Question area -->
                    <Border Grid.Row="1"
                            Background="#0d1b2a"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,8">
                        <StackPanel x:Name="QuizPanel"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Welcome to the Cybersecurity Quiz!"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Test your knowledge across 12 questions covering passwords, phishing, safe browsing, and more. Press Start Quiz when you're ready!"
                                       Foreground="#aaa"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Feedback area -->
                    <Border Grid.Row="2"
                            x:Name="FeedbackBorder"
                            Background="#0f3460"
                            CornerRadius="8"
                            Padding="12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="FeedbackText"
                                   Foreground="White"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─────────────── ACTIVITY LOG TAB ─────────────── -->
            <TabItem Header="📜  Activity Log">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Activity Log"
                                   Foreground="#e94560"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>
                        <Button Content="🗑  Clear Log"
                                Style="{StaticResource GreyButton}"
                                HorizontalAlignment="Right"
                                Click="ClearLog_Click"/>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="#0d1b2a"
                            CornerRadius="8"
                            Padding="8">
                        <ScrollViewer x:Name="LogScroller"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LogPanel"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button x:Name="ShowMoreBtn"
                                Content="Show More"
                                Style="{StaticResource GreyButton}"
                                Visibility="Collapsed"
                                Click="ShowMoreLog_Click"
                                Margin="0,0,8,0"/>
                        <TextBlock x:Name="LogCountText"
                                   Foreground="#aaa"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>

